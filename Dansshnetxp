# 🔐 DADOS DO CLIENTE (NÃO ALTERE!)
CHAVE_VIP="DANSSH-CLIENTE-001"
IP_LIBERADO="143.14.79.48"

# CORES
ROSA='\033[1;35m'
CIANO='\033[1;36m'
VERDE='\033[1;32m'
VERMELHO='\033[1;31m'
RESET='\033[0m'

# VERIFICA ROOT
if [ "$(id -u)" -ne 0 ]; then
    echo -e "${VERMELHO}❌ ERRO: Execute como ROOT!${RESET}"
    exit 1
fi

# PEGA IP ATUAL
IP_ATUAL=$(hostname -I | awk '{print $1}')

# TELA DE LOGIN
clear
echo -e "${ROSA}=============================================${RESET}"
echo -e "${CIANO}🐇 𝐃𝐀𝐍𝐒𝐒𝐇 𝐁𝐔𝐍𝐍𝐘 𝐏𝐑𝐎 🐇${RESET}"
echo -e "${ROSA}🔑 ACESSO EXCLUSIVO VIP${RESET}"
echo -e "${ROSA}=============================================${RESET}"
read -p "Digite sua CHAVE DE ACESSO: " CHAVE_DIGITADA

# VALIDA CHAVE
if [ "$CHAVE_DIGITADA" != "$CHAVE_VIP" ]; then
    echo -e "${VERMELHO}❌ CHAVE INVÁLIDA!${RESET}"
    exit 1
fi

# VALIDA IP
if [ "$IP_ATUAL" != "$IP_LIBERADO" ]; then
    echo -e "${VERMELHO}❌ VPS NÃO AUTORIZADA!${RESET}"
    echo -e "${VERMELHO}🔒 SOMENTE IP: $IP_LIBERADO${RESET}"
    exit 1
fi

echo -e "${VERDE}✅ AUTORIZADO! CARREGANDO SISTEMA...${RESET}"
sleep 1

# BAIXA O SISTEMA PRINCIPAL
curl -s -o /usr/local/bin/danssh https://raw.githubusercontent.com/Dandandan0307/Dansshnetxp/main/sistema-completo.sh
chmod +x /usr/local/bin/danssh
cp /usr/local/bin/danssh /bin/danssh
chmod +x /bin/danssh

echo -e "${VERDE}✅ SISTEMA CARREGADO!${RESET}"
sleep 1

# ABRE O PAINEL
exec danssh
