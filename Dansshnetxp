#!/bin/bash
# INSTALADOR CLIENTE DANSSH PRO - VERSÃO SEGURA
# ACESSO EXCLUSIVO - LICENÇA VENDA - BLOQUEADO POR IP + CHAVE
# USUÁRIO: Dandandan0307 | REPOSITÓRIO: Dansshnetxp

# 🔐 AQUI VOCÊ COLOCA OS DADOS DO CLIENTE ANTES DE MANDAR
# EXEMPLO: CHAVE_VIP="DANSSH-CLIENTE-JOAO-001" | IP_LIBERADO="143.14.79.48"
CHAVE_VIP="COLOQUE_AQUI_CHAVE_DO_CLIENTE"
IP_LIBERADO="COLOQUE_AQUI_IP_DA_VPS_DELE"

# CORES
VERDE='\033[1;32m'
VERMELHO='\033[1;31m'
AZUL='\033[1;34m'
RESET='\033[0m'

# VERIFICA SE É ROOT
if [ "$(id -u)" -ne 0 ]; then
    echo -e "${VERMELHO}❌ ERRO: Execute como ROOT!${RESET}"
    exit 1
fi

# PEGA O IP ATUAL DA VPS
IP_ATUAL=$(hostname -I | awk '{print $1}')

# TELA DE LOGIN
clear
echo -e "${AZUL}=============================================${RESET}"
echo -e "${VERDE}🔑 PAINEL DANSSH - ACESSO VIP${RESET}"
echo -e "${AZUL}=============================================${RESET}"
read -p "Digite sua CHAVE DE ACESSO: " CHAVE_DIGITADA

# ✅ PRIMEIRA VERIFICAÇÃO: CHAVE CORRETA?
if [ "$CHAVE_DIGITADA" != "$CHAVE_VIP" ]; then
    echo -e "${VERMELHO}❌ CHAVE INVÁLIDA! ACESSO NEGADO!${RESET}"
    exit 1
fi

# ✅ SEGUNDA VERIFICAÇÃO: É A VPS AUTORIZADA?
if [ "$IP_ATUAL" != "$IP_LIBERADO" ]; then
    echo -e "${VERMELHO}❌ VPS NÃO AUTORIZADA! ESSE ACESSO SÓ FUNCIONA NO IP: $IP_LIBERADO${RESET}"
    exit 1
fi

echo -e "${VERDE}✅ AUTORIZADO! BAIXANDO SISTEMA...${RESET}"
sleep 1.5

# BAIXA O SISTEMA PRINCIPAL
curl -s -o /usr/local/bin/danssh https://raw.githubusercontent.com/Dandandan0307/Dansshnetxp/main/sistema-completo.sh
chmod +x /usr/local/bin/danssh
cp /usr/local/bin/danssh /bin/danssh
chmod +x /bin/danssh

echo -e "${VERDE}✅ INSTALADO COM SUCESSO!${RESET}"
echo -e "${CIANO}🔒 LICENÇA VINCULADA AO IP: $IP_ATUAL${RESET}"
sleep 1

exec danssh
